# EduGenie Configuration Settings

# Google Gemini API Credentials
# Replace with your actual Gemini API key from Google AI Studio
GEMINI_API_KEY=your_gemini_api_key_here

# Local AI Model Settings
# Default is MBZUAI/LaMini-Flan-T5-248M (approx. 990MB)
# Lightweight option: MBZUAI/LaMini-Flan-T5-78M (approx. 300MB)
LAMINI_MODEL_ID=MBZUAI/LaMini-Flan-T5-248M

# Server Settings
HOST=127.0.0.1
PORT=8000
